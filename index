        let currentIndex = 0;
        let score = 0;

        function showUnit(unitNum) {
            document.getElementById('mainMenu').style.display = 'none';
            document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
            document.getElementById('unit' + unitNum).classList.add('active');
            currentUnit = unitNum;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function backToMenu() {
            document.getElementById('mainMenu').style.display = 'grid';
            document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
            document.getElementById('quizContainer').classList.remove('active');
            document.getElementById('motivationSection').classList.remove('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function backToLearning() {
            document.getElementById('quizContainer').classList.remove('active');
            document.getElementById('motivationSection').classList.remove('active');
            document.getElementById('unit' + currentUnit).classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function startTest(unit, mode) {
            currentUnit = unit;
            currentMode = mode;
            currentQuestions = [...questionBank[unit][mode]];
            currentIndex = 0;
            score = 0;
            
            document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
            document.getElementById('quizContainer').classList.add('active');
            document.getElementById('motivationSection').classList.remove('active');
            
            const modeNames = { mcq: 'MCQ Test', fillup: 'Fill-up Test', twomark: 'Two-Mark Test' };
            document.getElementById('testTitle').textContent = 'Unit ' + unit + ' - ' + modeNames[mode];
            
            showQuestion();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showQuestion() {
            const q = currentQuestions[currentIndex];
            const container = document.getElementById('questionContainer');
            const total = currentMode === 'twomark' ? currentQuestions.length * 2 : currentQuestions.length;
            
            document.getElementById('totalQuestions').textContent = total;
            document.getElementById('currentScore').textContent = score;
            document.getElementById('questionNum').textContent = currentIndex + 1;
            document.getElementById('totalQ').textContent = currentQuestions.length;
            document.getElementById('progressBar').style.width = ((currentIndex / currentQuestions.length) * 100) + '%';
            
            let html = '<div class="question-box">';
            html += '<div class="question-text">📝 Question ' + (currentIndex + 1) + ': ' + q.q + '</div>';
            
            if (currentMode === 'mcq') {
                html += '<div class="options">';
                q.options.forEach((opt, idx) => {
                    html += '<div class="option" onclick="checkMCQ(' + idx + ', ' + q.correct + ')">' + 
                            String.fromCharCode(65 + idx) + '. ' + opt + '</div>';
                });
                html += '</div>';
            } else if (currentMode === 'fillup') {
                html += '<input type="text" id="fillupAnswer" placeholder="Type your answer here..." onkeypress="if(event.key===\'Enter\')checkFillup(\'' + q.answer.replace(/'/g, "\\'") + '\')">';
                html += '<button class="btn" onclick="checkFillup(\'' + q.answer.replace(/'/g, "\\'") + '\')" style="margin-top: 15px;">✓ Submit Answer</button>';
            } else {
                html += '<div style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); padding: 20px; border-radius: 10px; margin-top: 15px;">';
                html += '<strong style="color: #2c3e50;">📝 Model Answer:</strong><br><br>';
                html += '<div style="color: #555; line-height: 1.8; white-space: pre-line;">' + q.answer + '</div>';
                html += '</div>';
                html += '<button class="btn" onclick="nextQuestion()" style="margin-top: 15px;">Next Question →</button>';
                score += 2;
            }
            
            html += '</div>';
            container.innerHTML = html;
        }

        function checkMCQ(selected, correct) {
            const options = document.querySelectorAll('.option');
            options.forEach(opt => opt.style.pointerEvents = 'none');
            
            if (selected === correct) {
                options[selected].classList.add('correct');
                score++;
            } else {
                options[selected].classList.add('wrong');
                options[correct].classList.add('correct');
            }
            
            document.getElementById('currentScore').textContent = score;
            
            setTimeout(() => {
                nextQuestion();
            }, 1500);
        }

        function checkFillup(correctAnswer) {
            const userAnswer = document.getElementById('fillupAnswer').value.trim().toLowerCase();
            if (!userAnswer) {
                alert('Please enter an answer!');
                return;
            }
            
            const isCorrect = userAnswer === correctAnswer.toLowerCase() || 
                            correctAnswer.toLowerCase().includes(userAnswer) ||
                            userAnswer.includes(correctAnswer.toLowerCase());
            
            const input = document.querySelector('input');
            input.disabled = true;
            
            if (isCorrect) {
                input.style.background = '#00b894';
                input.style.color = 'white';
                input.value = '✓ Correct! ' + input.value;
                score++;
            } else {
                input.style.background = '#d63031';
                input.style.color = 'white';
                input.value = '✗ Correct answer: ' + correctAnswer;
            }
            
            document.getElementById('currentScore').textContent = score;
            
            setTimeout(() => {
                nextQuestion();
            }, 2000);
        }

        function nextQuestion() {
            currentIndex++;
            if (currentIndex < currentQuestions.length) {
                showQuestion();
            } else {
                showMotivation();
            }
        }

        function showMotivation() {
            document.getElementById('quizContainer').classList.remove('active');
            const motivationDiv = document.getElementById('motivationSection');
            motivationDiv.classList.add('active');
            
            const total = currentMode === 'twomark' ? currentQuestions.length * 2 : currentQuestions.length;
