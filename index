                emoji = '👏🎉';
                message = 'GREAT JOB! You have a strong understanding of the concepts. Just a little more practice and you will be perfect!';
            } else if (percentage >= 60) {
                emoji = '👍👍';
                message = 'GOOD EFFORT! You are on the right track. Review the topics once more and try again to improve your score!';
            } else if (percentage >= 50) {
                emoji = '📚✏️📚';
                message = 'KEEP LEARNING! You are making progress. Don\'t give up - practice makes perfect. Review the material and try again!';
            } else {
                emoji = '💪💪';
                message = 'NEVER GIVE UP! Every expert was once a beginner. Take time to review the concepts thoroughly and try again. You can definitely do this!';
            }
            
            message += '<br><br>📊 Your Score: <strong>' + score + ' / ' + total + '</strong> (' + percentage.toFixed(1) + '%)';
            message += '<br><br>🎓 "Success is not final, failure is not fatal: it is the courage to continue that counts." - Winston Churchill';
